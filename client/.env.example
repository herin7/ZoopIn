# --- ZoopIn Client Configuration ---

# The URL of the backend API (without trailing slash)
# Default: http://localhost:5000
VITE_API_URL=http://localhost:5000

# The URL of the socket.io server
# Default: http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000

# Optionally, you can add Cloudinary client-side upload configuration
# if you decide to upload directly from the frontend.
# VITE_CLOUDINARY_UPLOAD_PRESET=zoopin_presets
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
